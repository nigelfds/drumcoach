#!/usr/bin/env bash
#
# pre-push hook — keep GitHub Pages in sync with the public/ subtree.
#
# When you push `main` (or `master`) to origin, this runs the same deploy you'd
# run by hand:
#     git subtree push --prefix public origin gh-pages
#
# Notes:
#  - Only fires for pushes of main/master to origin. The inner push to
#    gh-pages does NOT re-trigger it (its ref isn't main/master).
#  - Runs *before* the push to main lands, but it deploys the exact commits
#    being pushed, so gh-pages matches main.
#  - If the deploy fails it only warns — your push to main still proceeds.
set -u

remote_name="$1"

DEPLOY_REMOTE="origin"
DEPLOY_BRANCH="gh-pages"
PREFIX="public"
ZERO="0000000000000000000000000000000000000000"

# Only auto-deploy when pushing to origin.
[ "$remote_name" = "$DEPLOY_REMOTE" ] || exit 0

# Decide whether this push includes main/master (git feeds ref lines on stdin).
deploy=0
while read -r local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/heads/main|refs/heads/master)
      if [ "$local_sha" != "$ZERO" ]; then deploy=1; fi  # skip branch deletions
      ;;
  esac
done

[ "$deploy" -eq 1 ] || exit 0

echo "↪ pre-push: deploying '$PREFIX/' → $DEPLOY_REMOTE/$DEPLOY_BRANCH (GitHub Pages)…"
if git subtree push --prefix "$PREFIX" "$DEPLOY_REMOTE" "$DEPLOY_BRANCH"; then
  echo "✓ pre-push: $DEPLOY_REMOTE/$DEPLOY_BRANCH updated."
else
  echo "⚠ pre-push: gh-pages deploy failed — your push to $remote_name will still proceed." >&2
  echo "  Re-run it manually: git subtree push --prefix $PREFIX $DEPLOY_REMOTE $DEPLOY_BRANCH" >&2
fi
exit 0
