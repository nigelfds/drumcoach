#!/usr/bin/env bash
#
# pre-push hook — keep GitHub Pages in sync with the public/ subtree.
#
# When you push `main` (or `master`) to origin, this splits the public/ subtree
# and FORCE-pushes it to the gh-pages branch. gh-pages is a generated deploy
# branch (its content is 100% derived from public/), so force-pushing is the
# right call: it avoids the "non-fast-forward" rejection you hit when gh-pages
# diverges (e.g. GitHub adds a CNAME commit when you set a custom domain).
#
# Notes:
#  - Only fires for main/master pushed to origin. The inner push to gh-pages is
#    not main/master, so it doesn't re-trigger this hook.
#  - Deploys the exact commit being pushed, so gh-pages matches main.
#  - If the deploy fails it only warns — your push to main still proceeds.
set -u

remote_name="$1"

DEPLOY_REMOTE="origin"
DEPLOY_BRANCH="gh-pages"
PREFIX="public"
ZERO="0000000000000000000000000000000000000000"

# Only auto-deploy when pushing to origin.
[ "$remote_name" = "$DEPLOY_REMOTE" ] || exit 0

# Find the commit of main/master in this push (git feeds ref lines on stdin).
main_sha=""
while read -r local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/heads/main|refs/heads/master)
      if [ "$local_sha" != "$ZERO" ]; then main_sha="$local_sha"; fi  # skip deletions
      ;;
  esac
done

[ -n "$main_sha" ] || exit 0

echo "↪ pre-push: deploying '$PREFIX/' → $DEPLOY_REMOTE/$DEPLOY_BRANCH (GitHub Pages)…"
split_sha="$(git subtree split --prefix "$PREFIX" "$main_sha" | tail -n1)"
if [ -n "$split_sha" ] && git push --force "$DEPLOY_REMOTE" "$split_sha:refs/heads/$DEPLOY_BRANCH"; then
  echo "✓ pre-push: $DEPLOY_REMOTE/$DEPLOY_BRANCH updated."
else
  echo "⚠ pre-push: gh-pages deploy failed — your push to $remote_name will still proceed." >&2
  echo "  Re-run manually:" >&2
  echo "    git push --force $DEPLOY_REMOTE \"\$(git subtree split --prefix $PREFIX main):refs/heads/$DEPLOY_BRANCH\"" >&2
fi
exit 0
